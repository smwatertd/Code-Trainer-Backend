# Application
APP__TITLE=Code Trainer API
APP__VERSION=0.1.0
APP__DEBUG=true
APP__DOCS_URL=/docs

# Database
# При make dev: DB__HOST=postgres (имя сервиса в docker-compose.dev.yml).
# Если видите FATAL: role "code_trainer" does not exist — том Postgres создан со
# старыми credentials. Либо: docker compose -f docker/docker-compose.dev.yml down -v
# и make dev заново, либо создайте роль вручную (см. README).
DB__HOST=postgres
DB__PORT=5432
DB__NAME=code_trainer
DB__USER=code_trainer
DB__PASSWORD=change_me
DB__ECHO=false
DB__DB_SCHEMA=public

# Redis (job queue; в Docker: redis://redis:6379/0)
REDIS__URL=redis://localhost:6379/0

# CORS (comma-separated)
CORS__ORIGINS=http://localhost:5173,http://127.0.0.1:5173

AUTH__SECRET_KEY=change-me-in-production-min-32-chars
AUTH__ISSUER=code-trainer
AUTH__AUDIENCE=code-trainer-api
# Access token TTL (minutes). Refresh token rotates on each /auth/refresh (30 days default).
AUTH__ACCESS_TOKEN_TTL_MINUTES=15

# Guest demo (anonymous checks without registration)
GUEST__ENABLED=true
# Для Playwright E2E (10+ demo checks подряд) в dev лучше 30+
GUEST__MAX_CHECKS_PER_MINUTE=30
GUEST__MAX_CONCURRENT_CHECKS=2

# Execution queue (set true in prod with separate worker process)
EXECUTION__USE_REDIS_STORE=false
EXECUTION__PREFER_DOCKER_RUNNER=true
EXECUTION__USE_WARM_RUNNERS=true
EXECUTION__WARM_RUNNER_RECYCLE_AFTER=500
