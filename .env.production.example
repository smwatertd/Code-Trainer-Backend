# Production — copy to .env on the server and fill secrets.

APP__TITLE=Code Trainer API
APP__VERSION=0.1.0
APP__DEBUG=false
APP__DOCS_URL=/docs

DB__HOST=postgres
DB__PORT=5432
DB__NAME=code_trainer
DB__USER=code_trainer
DB__PASSWORD=change_me_strong_password
DB__ECHO=false
DB__DB_SCHEMA=public

REDIS__URL=redis://redis:6379/0

# HTTPS URL of the frontend (self-signed cert on IP is fine for CORS).
CORS__ORIGINS=https://92.63.102.50

AUTH__SECRET_KEY=change-me-generate-64-char-random-secret
AUTH__ISSUER=code-trainer
AUTH__AUDIENCE=code-trainer-api
AUTH__ACCESS_TOKEN_TTL_MINUTES=15

GUEST__ENABLED=true
GUEST__MAX_CHECKS_PER_MINUTE=20
GUEST__MAX_CONCURRENT_CHECKS=2

EXECUTION__USE_REDIS_STORE=false
EXECUTION__PREFER_DOCKER_RUNNER=true
EXECUTION__USE_WARM_RUNNERS=true
EXECUTION__WARM_RUNNER_RECYCLE_AFTER=500
